<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Keys NOT expressible via INFOPLIST_KEY_* build settings.
         Other keys (LSUIElement, LSApplicationCategoryType, bundle
         identifiers, deployment target, etc.) are still driven from
         the pbxproj build settings and merged on top of this file
         at build time (GENERATE_INFOPLIST_FILE = YES). -->

    <!-- ===================================================
         Sparkle auto-update configuration
         =================================================== -->

    <!-- Appcast feed URL served from the main branch on GitHub.
         Case-sensitive in raw.githubusercontent.com URLs. -->
    <key>SUFeedURL</key>
    <string>https://raw.githubusercontent.com/magicnight/Mac-MLX/main/appcast.xml</string>

    <!-- Public EdDSA key (base64) generated by Sparkle's generate_keys.
         TODO: replace the placeholder below with the real public key
         after running scripts/generate_sparkle_keys.sh. Sparkle will
         refuse to install an update whose signature doesn't validate
         against this key. -->
    <key>SUPublicEDKey</key>
    <string>REPLACE_WITH_OUTPUT_OF_GENERATE_KEYS</string>

    <!-- Out-of-process installer service (Sparkle 2.x). Recommended
         even without hardened runtime so Gatekeeper treats the updater
         as a separate process during the atomic swap. -->
    <key>SUEnableInstallerLauncherService</key>
    <true/>

    <!-- Don't ask users on every launch; show weekly prompt instead. -->
    <key>SUScheduledCheckInterval</key>
    <integer>604800</integer>
</dict>
</plist>
