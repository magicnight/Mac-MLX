# Xcode — user-specific data (must use **/ to recurse, plain *.xcodeproj/ only matches at root)
**/xcuserdata/
*.xcuserstate
**/*.xcuserdatad/

# Xcode — build artifacts
build/
dist/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Packages/

# Python — uv managed
__pycache__/
*.pyc
*.pyo
.venv/          # uv creates venv here, never commit it
*.egg-info/
# Note: uv.lock SHOULD be committed (do not ignore it)
# Note: pyproject.toml SHOULD be committed

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
*.log

# Secrets & signing
*.p12
*.mobileprovision
ExportOptions.plist
!scripts/ExportOptions.plist
sparkle_private_key*

# Local dev overrides
.env
.env.local

# OMC — runtime state (plans/ and project-memory.json are committed)
.omc/sessions/
.omc/state/
.omc/logs/
.omc/research/
.omc/notepad.md
