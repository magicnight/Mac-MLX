# Brewfile — macOS development toolchain
# Run: brew bundle
# This installs all tools needed to build and develop mac-mlx.

# --- Core build tools ---
brew "uv"              # Python package manager (required for backend)
brew "create-dmg"      # DMG packaging for releases

# --- Optional dev tools ---
brew "git-lfs"         # Large file support (for model files in testing)
brew "swiftformat"     # Swift code formatter
brew "swiftlint"       # Swift linter

# --- Cask (GUI apps, optional) ---
# cask "visual-studio-code"  # uncomment if needed
